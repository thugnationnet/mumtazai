# =============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# This file serves as a template for all required environment variables

# =============================================================================
# API & APPLICATION URLS
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Backend API URL (for server-side API route proxying)
# In production, the Next.js server uses this to reach the backend
BACKEND_BASE_URL=http://127.0.0.1:3005

# Chat/Subscription backend URL (universal-chat-backend on port 3008)
# Required for: /api/subscriptions/*, /api/stripe/checkout, /api/stripe/verify-session
# Without this, subscription routes proxy to the main backend (3005) which returns 404
CHAT_BACKEND_URL=http://127.0.0.1:3008

# =============================================================================
# AI MODEL API KEYS
# =============================================================================
# OpenAI API Configuration
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API Configuration  
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google/Gemini API Configuration
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Cohere API Configuration
NEXT_PUBLIC_COHERE_API_KEY=your_cohere_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# =============================================================================
# TRANSLATION & LANGUAGE SERVICES
# =============================================================================
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
NEXT_PUBLIC_GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
NEXT_PUBLIC_DEEPL_API_KEY=your_deepl_api_key_here
DEEPL_API_KEY=your_deepl_api_key_here

# =============================================================================
# VOICE & AUDIO SERVICES
# =============================================================================
NEXT_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
NEXT_PUBLIC_AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_email_app_password
MAIL_FROM=your_email@gmail.com
MAIL_TO=mumtazai2.0@gmail.com

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
IPINFO_API_TOKEN=your_ipinfo_token_here
NEXT_PUBLIC_RUNWAYML_API_KEY=your_runwayml_api_key_here
RUNWAYML_API_KEY=your_runwayml_api_key_here

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your_super_secure_jwt_secret_change_in_production
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=your_database_connection_string_here
REDIS_URL=your_redis_connection_string_here

# =============================================================================
# FEATURE FLAGS & CONFIGURATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_ENABLE_MULTILINGUAL=true
NEXT_PUBLIC_ENABLE_VOICE_FEATURES=true
NEXT_PUBLIC_ENABLE_PDF_UPLOAD=true
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_FALLBACK_LANGUAGE=en
NEXT_PUBLIC_MAX_FILE_SIZE=10
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,txt

# =============================================================================
# FILE UPLOADS (S3 PRESIGN)
# =============================================================================
# Server-side only (used by /api/uploads/presign). Do NOT expose real keys publicly.
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_UPLOAD_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_API_RATE_LIMIT=100
NEXT_PUBLIC_API_RATE_WINDOW=60000