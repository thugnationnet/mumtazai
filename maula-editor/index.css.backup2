@import "tailwindcss";

/* Thin horizontal scrollbar for debug tabs */
.debug-tabs-scroll {
  scrollbar-width: thin;
  scrollbar-color: rgba(128,128,128,0.3) transparent;
}
.debug-tabs-scroll::-webkit-scrollbar {
  height: 3px;
}
.debug-tabs-scroll::-webkit-scrollbar-track {
  background: transparent;
}
.debug-tabs-scroll::-webkit-scrollbar-thumb {
  background: rgba(128,128,128,0.35);
  border-radius: 3px;
}
.debug-tabs-scroll::-webkit-scrollbar-thumb:hover {
  background: rgba(128,128,128,0.6);
}

/* ============================================
   Complete Theme System
   All themes with consistent styling
   ============================================ */

/* Base Theme Variables (Charcoal Aurora Default) */
:root {
  --vscode-bg: #0a0c10;
  --vscode-sidebar: #0e1117;
  --vscode-activitybar: #080a0e;
  --vscode-editor: #0a0c10;
  --vscode-panel: #0e1117;
  --vscode-border: #1e2530;
  --vscode-accent: #00d4aa;
  --vscode-accent-hover: #00f5c4;
  --vscode-text: #e0e6ed;
  --vscode-text-muted: #8b9cb3;
  --vscode-icon: #00d4aa;
  --vscode-icon-inactive: #5a8a8a;
  --vscode-selection: #1a3a4a;
  --vscode-hover: #151b24;
  --vscode-active: #1e2530;
  --vscode-success: #00d68f;
  --vscode-warning: #ffaa00;
  --vscode-error: #ff4d6a;
}

/* ============================================
   Light Theme
   ============================================ */
/* VS Code Dark → Razer Black: pitch black + electric blue */
.dark:not(.theme-github-dark):not(.theme-dracula):not(.theme-nord):not(.theme-monokai):not(.theme-solarized-dark):not(.theme-one-dark):not(.theme-steel):not(.theme-charcoal-aurora):not(.high-contrast) {
  --vscode-bg: #030306;
  --vscode-sidebar: #060610;
  --vscode-activitybar: #030306;
  --vscode-editor: #030306;
  --vscode-panel: #060610;
  --vscode-border: #0e1028;
  --vscode-accent: #0066ff;
  --vscode-accent-hover: #3388ff;
  --vscode-text: #4488cc;
  --vscode-text-muted: #1a3366;
  --vscode-icon: #3366aa;
  --vscode-icon-inactive: #1a2244;
  --vscode-selection: #0a1a3a;
  --vscode-hover: #080812;
  --vscode-active: #0c0c1a;
  --vscode-success: #00ff88;
  --vscode-warning: #ffaa00;
  --vscode-error: #ff3355;
}

.light,
[data-theme="light"] {
  --vscode-bg: #ffffff;
  --vscode-sidebar: #f3f3f3;
  --vscode-activitybar: #e8e8e8;
  --vscode-editor: #ffffff;
  --vscode-panel: #f3f3f3;
  --vscode-border: #e0e0e0;
  --vscode-accent: #0078d4;
  --vscode-accent-hover: #106ebe;
  --vscode-text: #333333;
  --vscode-text-muted: #666666;
  --vscode-selection: #add6ff;
  --vscode-hover: #e8e8e8;
  --vscode-active: #dddddd;
  --vscode-success: #388e3c;
  --vscode-warning: #f57c00;
  --vscode-error: #d32f2f;
}

/* Light Theme Specific Styles */
.light ::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

.light ::-webkit-scrollbar-track {
  background: #f3f3f3;
}

.light ::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 5px;
}

.light ::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

.light ::selection {
  background: #add6ff;
  color: #333333;
}

.light input,
.light textarea,
.light select {
  background: #ffffff;
  border: 1px solid #cecece;
  color: #333333;
}

.light input:focus,
.light textarea:focus,
.light select:focus {
  border-color: #0078d4;
  outline: none;
  box-shadow: 0 0 0 1px #0078d4;
}

/* ============================================
   High Contrast Theme
   ============================================ */
.high-contrast {
  --vscode-bg: #000000;
  --vscode-sidebar: #000000;
  --vscode-activitybar: #000000;
  --vscode-editor: #000000;
  --vscode-panel: #000000;
  --vscode-border: #ffffff;
  --vscode-accent: #ffff00;
  --vscode-accent-hover: #ffff00;
  --vscode-text: #ffffff;
  --vscode-text-muted: #ffffff;
  --vscode-selection: #ffff00;
  --vscode-hover: #333333;
  --vscode-active: #444444;
  --vscode-success: #00ff00;
  --vscode-warning: #ffff00;
  --vscode-error: #ff0000;
}

.high-contrast ::-webkit-scrollbar {
  width: 12px;
  height: 12px;
}

.high-contrast ::-webkit-scrollbar-track {
  background: #000000;
  border: 1px solid #ffffff;
}

.high-contrast ::-webkit-scrollbar-thumb {
  background: #ffffff;
  border: 1px solid #000000;
}

.high-contrast ::-webkit-scrollbar-thumb:hover {
  background: #ffff00;
}

.high-contrast ::selection {
  background: #ffff00;
  color: #000000;
}

.high-contrast input,
.high-contrast textarea,
.high-contrast select {
  background: #000000;
  border: 2px solid #ffffff;
  color: #ffffff;
}

.high-contrast input:focus,
.high-contrast textarea:focus,
.high-contrast select:focus {
  border-color: #ffff00;
  outline: none;
  box-shadow: 0 0 0 2px #ffff00;
}

.high-contrast button:focus {
  outline: 2px solid #ffff00;
  outline-offset: 2px;
}

/* ============================================
   UNIVERSAL DARK THEME OVERRIDES
   Applies to ALL dark themes to fix white backgrounds
   ============================================ */
.dark .bg-white,
.dark [class*="bg-white"],
.theme-github-dark .bg-white,
.theme-dracula .bg-white,
.theme-nord .bg-white,
.theme-monokai .bg-white,
.theme-solarized-dark .bg-white,
.theme-one-dark .bg-white,
.theme-steel .bg-white,
.theme-charcoal-aurora .bg-white {
  background: var(--vscode-sidebar, #0d0d0d) !important;
}

/* Gray backgrounds for all dark themes */
.dark .bg-gray-50,
.dark .bg-gray-100,
.dark .bg-gray-200,
.theme-github-dark .bg-gray-50,
.theme-github-dark .bg-gray-100,
.theme-github-dark .bg-gray-200,
