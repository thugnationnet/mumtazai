/* ============================================
   GitHub Dark Theme
   ============================================ */
.theme-github-dark {
  --vscode-bg: #020408;
  --vscode-sidebar: #040810;
  --vscode-activitybar: #020408;
  --vscode-editor: #020408;
  --vscode-panel: #040810;
  --vscode-border: #081020;
  --vscode-accent: #00aaff;
  --vscode-accent-hover: #40ccff;
  --vscode-text: #3399bb;
  --vscode-text-muted: #144466;
  --vscode-selection: #0a2050;
  --vscode-hover: #060a14;
  --vscode-active: #0a1018;
  --vscode-success: #00e060;
  --vscode-warning: #ffcc00;
  --vscode-error: #ff4040;
}

.theme-github-dark ::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

.theme-github-dark ::-webkit-scrollbar-track {
  background: #060a14;
}

.theme-github-dark ::-webkit-scrollbar-thumb {
  background: #0e1830;
  border-radius: 5px;
}

.theme-github-dark ::-webkit-scrollbar-thumb:hover {
  background: #182848;
}

.theme-github-dark ::selection {
  background: #00aaff30;
  color: #c8d4e0;
}

.theme-github-dark input,
.theme-github-dark textarea,
.theme-github-dark select {
  background: #040610;
  border: 1px solid #0e1830;
  color: #c8d4e0;
}

.theme-github-dark input:focus,
.theme-github-dark textarea:focus,
.theme-github-dark select:focus {
  border-color: #00aaff;
  outline: none;
  box-shadow: 0 0 0 2px rgba(0, 170, 255, 0.3), 0 0 15px rgba(0, 170, 255, 0.15);
}

/* GitHub Dark - White Background Overrides */
.theme-github-dark .bg-white,
.theme-github-dark .bg-gray-50,
.theme-github-dark .bg-gray-100,
.theme-github-dark .bg-gray-200 {
  background: #080c18 !important;
}

.theme-github-dark .text-gray-900,
.theme-github-dark .text-gray-800 {
  color: #c8d4e0 !important;
}

.theme-github-dark .border-gray-200,
.theme-github-dark .border-gray-300 {
  border-color: #0e1830 !important;
