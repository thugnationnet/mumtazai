/* ============================================
   Dracula Theme
   ============================================ */
.theme-dracula {
  --vscode-bg: #04030a;
  --vscode-sidebar: #08060e;
  --vscode-activitybar: #04030a;
  --vscode-editor: #04030a;
  --vscode-panel: #08060e;
