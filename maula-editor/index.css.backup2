  --vscode-text-muted: #4a2868;
  --vscode-selection: #1a0a40;
  --vscode-hover: #0a081a;
  --vscode-active: #100c1e;
  --vscode-success: #00ff66;
  --vscode-warning: #ff8844;
  --vscode-error: #ff2244;
}

