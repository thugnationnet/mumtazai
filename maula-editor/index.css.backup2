.theme-solarized-dark h2,
.theme-solarized-dark h3,
.theme-solarized-dark h4,
.theme-solarized-dark .text-vscode-text {
  color: #44aa99 !important;
  text-shadow: 0 0 12px rgba(0, 204, 187, 0.4);
}
.theme-solarized-dark .text-vscode-accent {
  color: #00ccbb !important;
  text-shadow: 0 0 15px rgba(0, 204, 187, 0.6), 0 0 30px rgba(0, 204, 187, 0.3);
}
.theme-solarized-dark svg {
  color: #1a4440 !important;
  transition: color 0.15s ease;
}
.theme-solarized-dark *:hover > svg,
.theme-solarized-dark button:hover svg {
  color: #339988 !important;
  filter: drop-shadow(0 0 4px rgba(0, 204, 187, 0.4));
}
.theme-solarized-dark .active svg,
.theme-solarized-dark [class*="border-l-2"] svg {
  color: #00ccbb !important;
  filter: drop-shadow(0 0 6px rgba(0, 204, 187, 0.5));
}
.theme-solarized-dark footer {
  background: #020606 !important;
  border-color: #082222 !important;
}
.theme-solarized-dark footer * {
  color: #1a4440 !important;
  text-shadow: none;
}
.theme-solarized-dark footer *:hover {
  color: #00ccbb !important;
  text-shadow: 0 0 8px rgba(0, 204, 187, 0.5);
}

/* --- Plasma Blue (one-dark): Blue-purple glow text --- */
.theme-one-dark .text-white,
.theme-one-dark .text-gray-100,
.theme-one-dark .text-gray-200,
.theme-one-dark .text-gray-300 {
  color: #4477aa !important;
  text-shadow: 0 0 8px rgba(85, 136, 255, 0.3);
}
.theme-one-dark * {
  color: #335588;
}
.theme-one-dark h1,
.theme-one-dark h2,
.theme-one-dark h3,
.theme-one-dark h4,
.theme-one-dark .text-vscode-text {
  color: #5588bb !important;
  text-shadow: 0 0 12px rgba(85, 136, 255, 0.4);
}
.theme-one-dark .text-vscode-accent {
  color: #5588ff !important;
  text-shadow: 0 0 15px rgba(85, 136, 255, 0.6), 0 0 30px rgba(85, 136, 255, 0.3);
}
.theme-one-dark svg {
  color: #1a3366 !important;
  transition: color 0.15s ease;
}
.theme-one-dark *:hover > svg,
.theme-one-dark button:hover svg {
  color: #4477aa !important;
  filter: drop-shadow(0 0 4px rgba(85, 136, 255, 0.4));
}
.theme-one-dark .active svg,
.theme-one-dark [class*="border-l-2"] svg {
  color: #5588ff !important;
  filter: drop-shadow(0 0 6px rgba(85, 136, 255, 0.5));
}
.theme-one-dark footer {
  background: #030408 !important;
  border-color: #0a1133 !important;
}
.theme-one-dark footer * {
  color: #1a3366 !important;
  text-shadow: none;
}
.theme-one-dark footer *:hover {
  color: #5588ff !important;
  text-shadow: 0 0 8px rgba(85, 136, 255, 0.5);
}

/* --- Steel: Metallic glow text --- */
.theme-steel .text-white,
.theme-steel .text-gray-100,
.theme-steel .text-gray-200,
.theme-steel .text-gray-300 {
  color: #5a6878 !important;
  text-shadow: 0 0 6px rgba(123, 138, 158, 0.2);
}
.theme-steel * {
  color: #4a5868;
}
.theme-steel h1,
.theme-steel h2,
.theme-steel h3,
.theme-steel h4,
.theme-steel .text-vscode-text {
  color: #6b7a8e !important;
  text-shadow: 0 0 8px rgba(123, 138, 158, 0.3);
}
.theme-steel .text-vscode-accent {
  color: #7b8a9e !important;
  text-shadow: 0 0 10px rgba(123, 138, 158, 0.4);
}
.theme-steel svg {
  color: #2e3844 !important;
  transition: color 0.15s ease;
}
.theme-steel *:hover > svg,
.theme-steel button:hover svg {
  color: #5a6878 !important;
  filter: drop-shadow(0 0 3px rgba(123, 138, 158, 0.3));
}
.theme-steel .active svg,
.theme-steel [class*="border-l-2"] svg {
  color: #7b8a9e !important;
  filter: drop-shadow(0 0 4px rgba(123, 138, 158, 0.4));
}
.theme-steel footer {
  background: #0a0c10 !important;
  border-color: #1a1e26 !important;
}
.theme-steel footer * {
  color: #2e3844 !important;
  text-shadow: none;
}
.theme-steel footer *:hover {
  color: #7b8a9e !important;
  text-shadow: 0 0 6px rgba(123, 138, 158, 0.4);
}

/* ============================================
   UNIVERSAL BUTTON AND LINK STYLE FOR ALL NEON THEMES
   Buttons use accent color text, no white
   ============================================ */
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) button {
  color: var(--vscode-text) !important;
  background: transparent !important;
}
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) button:hover {
  color: var(--vscode-accent) !important;
  background: var(--vscode-hover) !important;
}
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) a:not(button) {
  color: var(--vscode-accent) !important;
}

/* Input fields match theme */
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) input,
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) textarea,
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) select {
  color: var(--vscode-text) !important;
}

/* kbd/code tags */
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) kbd,
.dark:not(.high-contrast):not(.light):not(.theme-charcoal-aurora) code {
  color: var(--vscode-text-muted) !important;
  background: var(--vscode-hover) !important;
  border-color: var(--vscode-border) !important;
}