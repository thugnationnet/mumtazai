/* ============================================
   UNIFIED GLOW-FROM-INSIDE EFFECT FOR ALL THEMES
   All text glows with the theme's accent color
   Dark black backgrounds everywhere
   ============================================ */

/* --- Razer Black: Blue glow text --- */
.dark:not([class*="theme-"]):not(.high-contrast) .text-white,
.dark:not([class*="theme-"]):not(.high-contrast) .text-gray-100,
.dark:not([class*="theme-"]):not(.high-contrast) .text-gray-200,
.dark:not([class*="theme-"]):not(.high-contrast) .text-gray-300 {
  color: #4488cc !important;
  text-shadow: 0 0 8px rgba(0, 102, 255, 0.3);
}
.dark:not([class*="theme-"]):not(.high-contrast) * {
  color: #3366aa;
}
.dark:not([class*="theme-"]):not(.high-contrast) h1,
.dark:not([class*="theme-"]):not(.high-contrast) h2,
.dark:not([class*="theme-"]):not(.high-contrast) h3,
.dark:not([class*="theme-"]):not(.high-contrast) h4,
.dark:not([class*="theme-"]):not(.high-contrast) .text-vscode-text {
  color: #5599dd !important;
  text-shadow: 0 0 12px rgba(0, 102, 255, 0.4);
}
.dark:not([class*="theme-"]):not(.high-contrast) .text-vscode-accent {
  color: #0066ff !important;
  text-shadow: 0 0 15px rgba(0, 102, 255, 0.6), 0 0 30px rgba(0, 102, 255, 0.3);
}
.dark:not([class*="theme-"]):not(.high-contrast) svg {
  color: #1a3366 !important;
  transition: color 0.15s ease;
}
.dark:not([class*="theme-"]):not(.high-contrast) *:hover > svg,
.dark:not([class*="theme-"]):not(.high-contrast) button:hover svg {
  color: #4488cc !important;
  filter: drop-shadow(0 0 4px rgba(0, 102, 255, 0.4));
}
.dark:not([class*="theme-"]):not(.high-contrast) .active svg,
.dark:not([class*="theme-"]):not(.high-contrast) [class*="border-l-2"] svg {
  color: #0066ff !important;
  filter: drop-shadow(0 0 6px rgba(0, 102, 255, 0.5));
}
.dark:not([class*="theme-"]):not(.high-contrast) footer {
  background: #030306 !important;
  border-color: #0a1122 !important;
}
.dark:not([class*="theme-"]):not(.high-contrast) footer * {
  color: #1a3366 !important;
  text-shadow: none;
}
.dark:not([class*="theme-"]):not(.high-contrast) footer *:hover {
  color: #0066ff !important;
  text-shadow: 0 0 8px rgba(0, 102, 255, 0.5);
}

