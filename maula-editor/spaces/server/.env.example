# =============================================================================
# NEURAL LINK BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
NEURAL_LINK_PORT=3200

# Frontend URL (for CORS and redirects)
NEURAL_LINK_FRONTEND_URL=https://editor.mumtaz.ai
FRONTEND_URL=https://editor.mumtaz.ai

# =============================================================================
# DATABASE - Separate PostgreSQL database for Neural Link
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/neural_link?schema=public

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT Secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Subdomain token secret (shared with main One Last AI app for handoff verification)
# This MUST match the SUBDOMAIN_TOKEN_SECRET in the main app
SUBDOMAIN_TOKEN_SECRET=shared-secret-with-main-app

# Encryption key for stored API credentials (generate with: openssl rand -hex 32)
CREDENTIAL_ENCRYPTION_KEY=

# =============================================================================
# AI PROVIDERS - Your own API keys for Neural Link
# =============================================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4, GPT-4o)
OPENAI_API_KEY=sk-...
OPENAI_VOICE_API_KEY=

# Google Gemini
GEMINI_API_KEY=AIza...

# Mistral
MISTRAL_API_KEY=...

# xAI (Grok)
XAI_API_KEY=xai-...

# Groq
GROQ_API_KEY=gsk_...

# Cerebras
CEREBRAS_API_KEY=...

# Fal.ai (Video/Image generation)
FAL_API_KEY=

# =============================================================================
# STRIPE - Same account as main app, separate products/prices
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MODE=test

# Webhook secret for Neural Link endpoint
NEURAL_LINK_STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# EMAIL (Optional - for notifications)
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
EMAIL_FROM=noreply@mumtaz.ai

# =============================================================================
# REDIS (Optional - for caching)
# =============================================================================
REDIS_URL=redis://localhost:6379/1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# Admin emails (comma-separated, for production admin access)
ADMIN_EMAILS=

# =============================================================================
# HOSTING - Deployed apps URL
# =============================================================================
HOSTED_APPS_URL=https://apps.mumtaz.ai

# =============================================================================
# AWS S3 - Image Storage (Signed URLs)
# =============================================================================
# If not set, image processing falls back to base64 data URIs
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-friend-zone-storage
IMAGE_S3_PREFIX=images
IMAGE_URL_TTL=900
