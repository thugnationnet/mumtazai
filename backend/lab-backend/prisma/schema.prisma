// ============================================
// CANVAS BUILDER - AI App Generation
// ============================================

enum CanvasFramework {
  vite_react
  nextjs
  html
  express
  fastapi
}

enum CanvasProjectStatus {
  draft
  building
  deployed
  error
}

enum CanvasBuildStatus {
  pending
  building
  success
  failed
}

enum CanvasDeploymentStatus {
  pending
  deploying
  live
  failed
  stopped
}

model CanvasProject {
  id              String               @id @default(cuid())
  userId          String
  name            String               @db.VarChar(200)
  description     String?              @db.VarChar(1000)
  framework       CanvasFramework      @default(vite_react)
  
  // Project structure stored as JSON
  files           Json                 @default("[]")
  pages           Json                 @default("[]")
  routes          Json                 @default("[]")
  apiRoutes       Json                 @default("[]")
  
  // i18n configuration
  languages       String[]             @default(["en"])
  defaultLanguage String               @default("en")
  translations    Json                 @default("{}")
  
  // Backend settings
  hasBackend      Boolean              @default(false)
  database        Json?
  
  // Deployment info
  subdomain       String?              @unique
  deploymentUrl   String?
  status          CanvasProjectStatus  @default(draft)
  
  // Build info
  lastBuildId     String?
  lastBuildStatus CanvasBuildStatus?
  lastBuildAt     DateTime?
  
  // Product source — which app created this project
  source          String?              @db.VarChar(20) // 'canvas-studio' | 'canvas-build'

  // Metadata
  thumbnail       String?
  tags            String[]             @default([])
  isPublic        Boolean              @default(false)
  viewCount       Int                  @default(0)
  forkCount       Int                  @default(0)
  forkedFromId    String?
  
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  
  // Relations
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  builds          CanvasBuild[]
  deployments     CanvasDeployment[]
  assets          CanvasAsset[]
  forkedFrom      CanvasProject?       @relation("ProjectForks", fields: [forkedFromId], references: [id])
  forks           CanvasProject[]      @relation("ProjectForks")
  
  @@index([userId])
  @@index([subdomain])
  @@index([status])
  @@index([isPublic])
  @@index([createdAt])
  @@map("canvas_projects")
}

// ============================================
// CANVAS BUILD PROJECTS (universal-chat overlay — separate table)
// Simpler schema for the canvas-build product inside universal-chat.
// Previously shared canvas_projects table with source-column isolation;
// now has its own dedicated table for true DB-level separation.
// ============================================

model CanvasBuildProject {
  id              String    @id @default(cuid())
  userId          String
  name            String    @db.VarChar(200)
  description     String?   @db.VarChar(1000)

  // Project files stored as JSON array of { path, name, content, language }
  files           Json      @default("[]")

  // Chat history — array of { role, content, timestamp }
  chatHistory     Json      @default("[]")

  // Arbitrary metadata (agent, model, etc.)
  metadata        Json      @default("{}")

  // Visual
  thumbnail       String?
  tags            String[]  @default([])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  builds          CanvasBuild[]

  @@index([userId])
  @@index([createdAt])
  @@map("canvas_build_projects")
}

model CanvasBuild {
  id              String             @id @default(cuid())
  projectId       String?            // canvas-studio projects (CanvasProject)
  buildProjectId  String?            // universal-chat projects (CanvasBuildProject)
  version         Int                @default(1)
  status          CanvasBuildStatus  @default(pending)
  
  // Build configuration
  framework       CanvasFramework
  buildCommand    String?
  
  // Build outputs
  logs            String?            @db.Text
  artifactUrl     String?
  containerImage  String?
  
  // Timing
  duration        Int?               // seconds
  createdAt       DateTime           @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Error info
  errorMessage    String?
  errorStack      String?            @db.Text
  
  // Relations
  project         CanvasProject?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buildProject    CanvasBuildProject? @relation(fields: [buildProjectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([buildProjectId])
  @@index([status])
  @@index([createdAt])
  @@map("canvas_builds")
}

model CanvasDeployment {
  id              String                  @id @default(cuid())
  projectId       String
  buildId         String?
  
  // Deployment info
  subdomain       String
  url             String
  status          CanvasDeploymentStatus  @default(pending)
  type            String                  @default("static") // static, container, serverless
  
  // Container/server info
  containerImage  String?
  containerPort   Int?
  healthCheckUrl  String?
  
  // SSL
  sslEnabled      Boolean                 @default(true)
  sslExpiresAt    DateTime?
  
  // Environment variables (encrypted)
  envVars         Json?                   @default("{}")
  
  // Traffic & analytics
  requestCount    Int                     @default(0)
  bandwidthUsed   BigInt                  @default(0)
  lastAccessedAt  DateTime?
  
  // Timing
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deployedAt      DateTime?
  
  // Relations
  project         CanvasProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([subdomain])
  @@index([status])
  @@map("canvas_deployments")
}

model CanvasTemplate {
  id              String          @id @default(cuid())
  name            String          @db.VarChar(100)
  description     String?         @db.VarChar(500)
  category        String          @default("landing") // landing, ecommerce, dashboard, blog, portfolio, saas
  framework       CanvasFramework @default(vite_react)
  
  // Template content
  files           Json            @default("[]")
  pages           Json            @default("[]")
  thumbnail       String?
  previewUrl      String?
  
  // Metadata
  features        String[]        @default([])
  tags            String[]        @default([])
  isPremium       Boolean         @default(false)
  price           Float?
  
  // Stats
  usageCount      Int             @default(0)
  rating          Float           @default(0)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([category])
  @@index([framework])
  @@index([isPremium])
  @@map("canvas_templates")
}

model CanvasDeployCredential {
  id              String    @id @default(cuid())
  userId          String
  provider        String    @db.VarChar(50)  // vercel, railway, netlify, cloudflare
  name            String    @default("Default") @db.VarChar(100)
  token           String    @db.Text         // AES-256-CBC encrypted
  teamId          String?   @db.VarChar(200)
  source          String    @default("") @db.VarChar(20)  // 'canvas-studio' | 'canvas-build' | '' (legacy/shared)
  isValid         Boolean   @default(true)
  lastValidatedAt DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, source])
  @@index([userId])
  @@index([userId, source])
  @@map("canvas_deploy_credentials")
}

// ============================================
// CANVAS ASSETS (Project files, images, fonts, etc.)
// ============================================

model CanvasAsset {
  id              String    @id @default(cuid())
  projectId       String
  userId          String

  // File info
  type            String    @default("other") @db.VarChar(20) // image, video, font, document, other
  originalName    String    @db.VarChar(255)
  originalSize    Int       // bytes
  optimizedSize   Int?      // bytes (after compression)
  mimeType        String?   @db.VarChar(100)

  // Storage
  storagePath     String    @db.VarChar(500) // local or S3 path
  cdnUrl          String    @db.VarChar(500)
  thumbnailUrl    String?   @db.VarChar(500)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  project         CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("canvas_assets")
}

// ============================================
// CANVAS MONITORING (Logs, errors, events)
// ============================================

model CanvasMonitoringLog {
  id              String    @id @default(cuid())
  projectId       String
  severity        String    @default("info") @db.VarChar(10) // critical, error, warning, info, debug
  message         String    @db.Text
  source          String?   @db.VarChar(50) // build, deploy, runtime, sandbox
  metadata        Json?

  createdAt       DateTime  @default(now())

  @@index([projectId])
  @@index([severity])
  @@index([createdAt])
  @@map("canvas_monitoring_logs")
}

model CanvasErrorGroup {
  id              String    @id @default(cuid())
  projectId       String
  fingerprint     String    // hash of error message + stack
  message         String    @db.Text
  severity        String    @default("error") @db.VarChar(10)
  stack           String?   @db.Text
  count           Int       @default(1)
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?
  firstSeen       DateTime  @default(now())
  lastSeen        DateTime  @default(now())

  @@unique([projectId, fingerprint])
  @@index([projectId])
  @@index([resolved])
  @@index([lastSeen])
  @@map("canvas_error_groups")
}

// ============================================
// APP HOSTING & BILLING (Canvas-Studio SaaS)
// ============================================

enum HostingTier {
  free
  starter
  pro
  business
}

enum HostingPlanStatus {
  active
  expired
  cancelled
  past_due
}

model AppHostingPlan {
  id                   String            @id @default(cuid())
  userId               String
  tier                 HostingTier       @default(free)
  status               HostingPlanStatus @default(active)
  
  // Billing
  price                Float             @default(0)
  billingCycle         SubscriptionPlan  @default(monthly)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  
  // Limits (per billing cycle)
  maxApps              Int               @default(1)
  maxBandwidthMb       Int               @default(100)      // MB per month
  maxRequestsPerMonth  Int               @default(1000)
  maxStorageMb         Int               @default(50)       // MB total storage
  customDomain         Boolean           @default(false)
  sslIncluded          Boolean           @default(true)
  prioritySupport      Boolean           @default(false)
  
  // Current usage (reset each billing cycle)
  currentBandwidthMb   Float             @default(0)
  currentRequests      Int               @default(0)
  currentStorageMb     Float             @default(0)
  currentApps          Int               @default(0)
  
  // Dates
  startDate            DateTime          @default(now())
  expiryDate           DateTime?
  lastResetAt          DateTime          @default(now())
  cancelledAt          DateTime?
  
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  
  // Relations
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords         AppUsageRecord[]
  
  @@unique([userId, tier])
  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@map("app_hosting_plans")
}

model AppUsageRecord {
  id                String         @id @default(cuid())
  userId            String
  hostingPlanId     String?
  deploymentId      String?
  projectId         String?
  appSource         String?        // 'canvas-studio' | 'canvas-build' — which product generated usage
  
  // Usage data
  eventType         String         // request, bandwidth, deploy, build, storage
  value             Float          @default(0)  // count or MB depending on type
  metadata          Json?          @default("{}")
  
  // Period tracking
  periodStart       DateTime
  periodEnd         DateTime
  
  createdAt         DateTime       @default(now())
  
  // Relations
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostingPlan       AppHostingPlan? @relation(fields: [hostingPlanId], references: [id])
  
  @@index([userId])
  @@index([hostingPlanId])
  @@index([eventType])
  @@index([periodStart, periodEnd])
  @@index([createdAt])
  @@map("app_usage_records")
}

// ============================================
// USER MEMORY PROFILE - Auto-memory + profile settings
// ============================================

model UserMemoryProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  
  // Profile fields
  enabled     Boolean  @default(false)
  userName    String   @default("")
  language    String   @default("")
  gender      String   @default("")
  dateOfBirth String   @default("")
  
  // Auto-extracted memories stored as JSON array
  // Each entry: { id, fact, category, createdAt }
  memories    Json     @default("[]")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_memory_profiles")
}

// ============================================
// USER PREFERENCES - All client-side prefs stored in DB
// ============================================

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  
  // Per-agent chat settings: { "agentId": { temperature, maxTokens, mode, systemPrompt } }
  agentSettings Json @default("{}")
  
  // Per-agent chat themes: { "agentId": "default" | "neural" }
  agentThemes   Json @default("{}")
  
  // Global site theme: "light" | "dark"
  siteTheme     String @default("light")
  
  // Chat history stored in DB (JSONB) — keyed by agentId
  // Each entry: { sessions: { sessionId: { id, name, messages, lastUpdated } }, activeSessionId }
  chatHistory   Json @default("{}")
  
  // Per-agent canvas chat messages: { "agentId": [{ id, role, content, timestamp }] }
  canvasMessages Json @default("{}")
  
  // UI state flags: { "canvas_sidebar_animated_agentId": true, "canvas_migrated": true, ... }
  uiFlags        Json @default("{}")
  
  // Per-message feedback: { "messageId": "up" | "down" }
  messageFeedback Json @default("{}")

  // Canvas-studio store states: { "canvas-deploy-store": {...}, "canvas-editor-settings": {...}, ... }
  // Replaces localStorage for all Zustand persist stores + deployment history
  canvasState     Json @default("{}")

  // Tool-specific state: { "domain_reputation": { history, watchlist, alerts, settings }, "whois_lookup": { history, favorites, settings }, ... }
  toolState       Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

// ============================================
// AUTH LOCKOUT — Progressive lockout system
// Tier 0: 3 fails → 15 min lock
// Tier 1: 3 fails after tier 0 → 24 hour lock
// Tier 2: 3 fails after tier 1 → permanent lock (contact support)
// ============================================

model AuthLockout {
  id              String    @id @default(cuid())
  email           String    @unique
  failedAttempts  Int       @default(0)
  lockoutTier     Int       @default(0)   // 0 = initial, 1 = after 15min, 2 = after 24h
  lockedUntil     DateTime?               // null = not locked, set when locked
  permanentlyLocked Boolean @default(false)
  lastFailedAt    DateTime?
  lastFailedIp    String?                  // last IP that failed (for support reference)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("auth_lockouts")
}
