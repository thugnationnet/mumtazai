  diff            String?   @db.Text // computed diff
  
  // Status
  status          String    @default("new") // new, passed, failed, updated
  matchPercentage Float?    @map("match_percentage") // 0-100
  
  // Metadata
  metadata        Json?     // { url, selector, viewport, etc. }
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@unique([userId, key])
  @@index([userId])
  @@map("test_snapshots")
}

// ============================================================================
// CLOUD INFRASTRUCTURE (DNS, SSL, storage, secrets, scaling)
