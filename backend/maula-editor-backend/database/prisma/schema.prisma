  merged          String?   @db.Text // merged result
  hasConflicts    Boolean   @default(false) @map("has_conflicts")
  conflictCount   Int       @default(0) @map("conflict_count")
  conflictDetails Json?     @map("conflict_details") // [{ line, ours, theirs }]
  
  // Status
  status          String    @default("pending") // pending, diffed, merged, conflict, resolved
  resolvedBy      String?   @map("resolved_by") // manual, auto, ai
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([userId, createdAt])
  @@map("diff_merges")
}

model ReviewComment {
