  name            String
  description     String?   @db.Text
  architecture    Json      @default("{}") // { components, dataFlows, trustBoundaries }
  threats         Json      @default("[]") // [{ id, category, description, severity, mitigation, status }]
  methodology     String    @default("STRIDE") // STRIDE, DREAD, PASTA

  // Summary
  riskLevel       String?   @map("risk_level") // low, medium, high, critical
  mitigatedCount  Int       @default(0) @map("mitigated_count")
  openCount       Int       @default(0) @map("open_count")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("threat_models")
}

model IncidentRecord {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")

  title           String
  description     String?   @db.Text
  severity        String    // critical, high, medium, low
  status          String    @default("open") // open, investigating, mitigating, resolved, closed
  category        String?   // breach, ddos, malware, unauthorized_access, data_leak

  // Timeline
  timeline        Json      @default("[]") // [{ timestamp, action, actor, detail }]
  affectedSystems Json      @default("[]") @map("affected_systems")
  rootCause       String?   @db.Text @map("root_cause")
  resolution      String?   @db.Text

  // Mitigation
  mitigationSteps Json      @default("[]") @map("mitigation_steps") // [{ step, status, assignee }]
  automated       Boolean   @default(false) // was mitigation automated?

  detectedAt      DateTime  @default(now()) @map("detected_at")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([severity])
  @@index([status])
  @@map("incident_records")
}

// ============================================================================
// EXTENSION MARKETPLACE — per-user installed extensions (DB-backed, no localStorage)
// ============================================================================

model UserExtension {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  extensionId     String    @map("extension_id")
  enabled         Boolean   @default(true)
  // Per-project enable/disable map: { [projectId]: boolean }
  projectEnabled  Json      @default("{}") @map("project_enabled")
  // Cached marketplace metadata at install time (so UI can render even if catalog changes)
  metadata        Json      @default("{}")
  installedAt     DateTime  @default(now()) @map("installed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([userId, extensionId])
  @@index([userId])
  @@map("user_extensions")
}
