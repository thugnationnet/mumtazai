  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@unique([userId, serviceName, environment])
  @@index([userId])
  @@map("cloud_scaling_configs")
}

// ============================================================================
// WORKFLOW AUTOMATION (Cron, queues, triggers, workflows, retry policies)
// ============================================================================

model ScheduledJob {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  
  // Job definition
  name            String
  description     String?   @db.Text
  jobType         String    @map("job_type") // cron, one_time, recurring
  
  // Schedule
  cronExpression  String?   @map("cron_expression") // for cron type
  interval        Int?      // seconds, for recurring type
  runAt           DateTime? @map("run_at") // for one_time type
  timezone        String    @default("UTC")
  
  // Action
  actionType      String    @map("action_type") // http, tool, pipeline, notification
  actionConfig    Json      @map("action_config") // { url, method, toolName, params }
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  status          String    @default("scheduled") // scheduled, running, paused, completed, failed
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  runCount        Int       @default(0) @map("run_count")
  failCount       Int       @default(0) @map("fail_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  executions      JobExecution[]
  
  @@index([userId])
  @@index([nextRunAt])
  @@index([status])
  @@map("scheduled_jobs")
}

model JobExecution {
  id              String    @id @default(cuid())
  jobId           String    @map("job_id")
  
  // Execution info
  executionNumber Int       @map("execution_number")
  status          String    @default("running") // running, success, failed, timeout, retrying
  
  // Result
  result          Json?
  errorMessage    String?   @map("error_message") @db.Text
  
  // Retry
  attempt         Int       @default(1)
  maxRetries      Int       @default(3) @map("max_retries")
  retryDelay      Int       @default(60) @map("retry_delay") // seconds
  
  // Timing
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?      @map("duration_ms")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  // Relations
  job             ScheduledJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  @@index([jobId, createdAt])
  @@index([status])
  @@map("job_executions")
}

model TaskQueue {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  
  // Queue config
  name            String
  description     String?
  concurrency     Int       @default(5)
  maxRetries      Int       @default(3) @map("max_retries")
  retryDelay      Int       @default(60) @map("retry_delay") // seconds
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  pendingCount    Int       @default(0) @map("pending_count")
  processingCount Int       @default(0) @map("processing_count")
  completedCount  Int       @default(0) @map("completed_count")
  failedCount     Int       @default(0) @map("fail_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  tasks           QueueTask[]
  
  @@unique([userId, name])
  @@index([userId])
  @@map("task_queues")
}

model QueueTask {
  id              String    @id @default(cuid())
  queueId         String    @map("queue_id")
  
  // Task definition
  taskType        String    @map("task_type") // http, tool, custom
  payload         Json
  priority        Int       @default(0) // higher = processed first
  
  // Status
  status          String    @default("pending") // pending, processing, completed, failed, dead
  attempt         Int       @default(0)
  
  // Result
  result          Json?
  errorMessage    String?   @map("error_message") @db.Text
  
  // Timing
  scheduledAt     DateTime  @default(now()) @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  // Relations
  queue           TaskQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  
  @@index([queueId, status, priority])
  @@index([status])
  @@map("queue_tasks")
}

model EventTrigger {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  
  // Trigger definition
  name            String
  description     String?
  
  // Event matching
  eventType       String    @map("event_type") // model.created, model.updated, webhook.received, cron.fired
  eventFilter     Json?     @map("event_filter") // { model, field, operator, value }
  
  // Action
  actionType      String    @map("action_type") // tool, http, notification, pipeline, workflow
  actionConfig    Json      @map("action_config")
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  lastFiredAt     DateTime? @map("last_fired_at")
  fireCount       Int       @default(0) @map("fire_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([eventType])
  @@map("event_triggers")
}

model Workflow {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  
  // Workflow definition
  name            String
  description     String?   @db.Text
  version         Int       @default(1)
  
  // Steps as directed graph (JSON)
  steps           Json      // [{ id, name, type, config, next[], condition? }]
  
  // Variables/context template
  inputSchema     Json?     @map("input_schema")
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  lastRunAt       DateTime? @map("last_run_at")
  runCount        Int       @default(0) @map("run_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  runs            WorkflowRun[]
  
  @@index([userId])
  @@map("workflows")
}

model WorkflowRun {
  id              String    @id @default(cuid())
  workflowId      String    @map("workflow_id")
  
  // Run info
  runNumber       Int       @map("run_number")
  inputData       Json?     @map("input_data")
  
  // Step execution log
  stepResults     Json?     @map("step_results") // [{ stepId, status, output, duration, error }]
  currentStepId   String?   @map("current_step_id")
  
  // Status
  status          String    @default("running") // running, success, failed, cancelled, paused
  outputData      Json?     @map("output_data")
  errorMessage    String?   @map("error_message") @db.Text
  
  // Timing
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?      @map("duration_ms")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  // Relations
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId, createdAt])
  @@index([status])
  @@map("workflow_runs")
}

model RetryPolicy {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  
  // Policy definition
  name            String
  description     String?
  
  // Retry config
  maxRetries      Int       @default(3) @map("max_retries")
  initialDelay    Int       @default(1000) @map("initial_delay") // ms
  maxDelay        Int       @default(300000) @map("max_delay") // ms (5 min)
  backoffType     String    @default("exponential") @map("backoff_type") // fixed, linear, exponential
  backoffMultiplier Float   @default(2.0) @map("backoff_multiplier")
  jitter          Boolean   @default(true) // add randomness to prevent thundering herd
  
  // Conditions
  retryOn         Json?     @map("retry_on") // [{ statusCode: 500 }, { error: "TIMEOUT" }]
  abortOn         Json?     @map("abort_on") // [{ statusCode: 400 }]
  
  // Stats
  timesApplied    Int       @default(0) @map("times_applied")
  successAfterRetry Int     @default(0) @map("success_after_retry")
  exhaustedCount  Int       @default(0) @map("exhausted_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@unique([userId, name])
  @@index([userId])
  @@map("retry_policies")
}

// ============================================================================
// COLLABORATION (Diff/merge, reviews, snapshots, live sessions)
