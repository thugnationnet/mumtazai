{
  "name": "canvas-studio-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "dev:watch": "nodemon --ext js --watch . server.js",
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "start": "node server.js",
    "lint": "eslint . --ext .js --fix",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-ecs": "^3.987.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^1.38.0",
    "@google/generative-ai": "^0.24.1",
    "@pinecone-database/pinecone": "^6.1.3",
    "@prisma/client": "^6.9.0",
    "@runwayml/sdk": "^3.11.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bullmq": "^5.66.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "mathjs": "^15.1.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.12",
    "openai": "^6.15.0",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.9.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "stripe": "^20.0.0",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "vm2": "^3.10.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-node": "^11.1.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.5.3"
  }
}
