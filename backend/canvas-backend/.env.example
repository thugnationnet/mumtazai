# Canvas Build Backend — Environment Variables
# Copy this file to .env and fill in the values

NODE_ENV=development
CANVAS_STUDIO_PORT=3202
CANVAS_STUDIO_FRONTEND_URL=http://localhost:3101

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=canvas_studio&sslmode=require"

# Authentication (JWT)
CANVAS_STUDIO_JWT_SECRET=
JWT_SECRET=
SUBDOMAIN_TOKEN_SECRET=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
ELEVENLABS_API_KEY=
FAL_API_KEY=
RUNWAYML_API_KEY=

# Stripe Billing
STRIPE_ACCOUNT_ID=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_MODE=test
STRIPE_WEBHOOK_SECRET=

# Redis (optional — falls back to in-memory)
REDIS_URL=

# AWS (for S3, ECS sandbox, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Email (SMTP)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Canvas Build <noreply@mumtaz.ai>"
SUPPORT_EMAIL=support@mumtaz.ai

# CORS
ALLOWED_ORIGINS=http://localhost:3101,https://build.mumtaz.ai

# Azure Content Safety (optional)
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=
