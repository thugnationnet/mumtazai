{
  "name": "mumtazai-canvas-build",
  "version": "1.0.0",
  "type": "module",
  "description": "Mumtaz AI Canvas Build Backend — AI App Builder",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:push": "npx prisma db push --schema=./database/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=./database/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=./database/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=./database/prisma/schema.prisma --port 5556"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.986.0",
    "@aws-sdk/client-ecs": "^3.986.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.986.0",
    "@aws-sdk/client-s3": "^3.986.0",
    "@aws-sdk/client-servicediscovery": "^3.986.0",
    "@aws-sdk/lib-dynamodb": "^3.986.0",
    "@aws-sdk/s3-request-presigner": "^3.986.0",
    "@prisma/client": "6.3.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dockerode": "^4.0.9",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "isomorphic-git": "^1.37.1",
    "jose": "^6.0.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "react-loading-skeleton": "^3.5.0",
    "sharp": "^0.33.5",
    "stripe": "^18.1.0",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "prisma": "6.3.1"
  }
}
