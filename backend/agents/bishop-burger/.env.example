# ============================================
# BISHOP-BURGER — Dedicated Agent Backend
# Copy this to .env and fill in real values
# ============================================

# Agent identity (do not change)
AGENT_ID=bishop-burger
PORT=4003

# Per-agent rate limit (messages per IP per hour)
AGENT_RATE_LIMIT_PER_IP=30

# Provider cascade — OPENAI is PRIMARY for Bishop Burger (culinary/creative content)
AGENT_PROVIDER_CASCADE=openai,xai,mistral
AGENT_PRIMARY_PROVIDER=openai

# Per-mode dedicated provider order
# chat: openai primary (GPT-4o best for rich culinary conversation)
AGENT_PROVIDER_CHAT=openai,xai,mistral
# code: mistral codestral purpose-built for code
AGENT_PROVIDER_CODE=mistral,openai,xai
# images: DALL-E (openai) must be primary for generate_image tool
AGENT_PROVIDER_IMAGES=openai,mistral,xai
# search: xAI Grok best for real-time web synthesis (restaurant trends, recipes)
AGENT_PROVIDER_SEARCH=xai,openai,mistral
# video: openai LLM calls generate_video tool → RunwayML does the actual generation
AGENT_PROVIDER_VIDEO=openai,xai,mistral

# Max tokens per response
AGENT_MAX_TOKENS=16384

# Max tool execution rounds
AGENT_MAX_TOOL_ROUNDS=3

# ===== AI Provider Keys =====
OPENAI_API_KEY=
OPENAI_API_KEY_BACKUP=
XAI_API_KEY=
MISTRAL_API_KEY=

# ===== RunwayML — Video Generation =====
# IMPORTANT: Must also be set in ecosystem.config.cjs env section
# because video-generation-service.js reads it at module load time
RUNWAY_API_KEY=

# ===== Database =====
UNIVERSAL_CHAT_DATABASE_URL=

# ===== Auth =====
JWT_SECRET=
SESSION_SECRET=

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100,https://mumtaz.ai,https://www.mumtaz.ai,https://chat.mumtaz.ai,https://bishop-burger.mumtaz.ai
