# ============================================
# COMEDY-KING — Dedicated Agent Backend
# Copy this to .env and fill in real values
# ============================================

# Agent identity (do not change)
AGENT_ID=comedy-king
PORT=4001

# Per-agent rate limit (messages per IP per hour)
AGENT_RATE_LIMIT_PER_IP=30

# Provider cascade — order: primary → fallback1 → fallback2
AGENT_PROVIDER_CASCADE=openai,xai,mistral
AGENT_PRIMARY_PROVIDER=openai

# Per-mode dedicated provider order
AGENT_PROVIDER_CHAT=openai,xai,mistral
AGENT_PROVIDER_CODE=mistral,openai,xai
AGENT_PROVIDER_IMAGES=openai,mistral,xai
AGENT_PROVIDER_SEARCH=xai,openai,mistral
AGENT_PROVIDER_VIDEO=openai,xai,mistral

# Max tokens per response
AGENT_MAX_TOKENS=16384

# Max tool execution rounds
AGENT_MAX_TOOL_ROUNDS=2

# ===== AI Provider Keys =====
OPENAI_API_KEY=
OPENAI_API_KEY_BACKUP=
XAI_API_KEY=
MISTRAL_API_KEY=

# ===== RunwayML — Video Generation =====
# IMPORTANT: Must also be set in ecosystem.config.cjs env section
RUNWAY_API_KEY=

# ===== Database =====
UNIVERSAL_CHAT_DATABASE_URL=

# ===== Auth =====
JWT_SECRET=
SESSION_SECRET=

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100,https://mumtaz.ai,https://www.mumtaz.ai,https://chat.mumtaz.ai,https://comedy-king.mumtaz.ai
