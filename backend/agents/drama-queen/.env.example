# Drama Queen — Agent Environment Variables
# Copy this to .env and fill in real values

NODE_ENV=production
AGENT_ID=drama-queen
PORT=4004

# ── Provider cascade (fallback order) ────────────────────────────────────────
# OpenAI is PRIMARY for Drama Queen (theatrical/emotional/dramatic persona)
# NOTE: These MUST also be set in ecosystem.config.cjs (ES module hoisting)
AGENT_PROVIDER_CASCADE=openai,xai,mistral
AGENT_PRIMARY_PROVIDER=openai

# Per-mode dedicated provider order
AGENT_PROVIDER_CHAT=openai,xai,mistral
AGENT_PROVIDER_CODE=mistral,openai,xai
AGENT_PROVIDER_IMAGES=openai,mistral,xai
AGENT_PROVIDER_SEARCH=xai,openai,mistral
AGENT_PROVIDER_VIDEO=openai,xai,mistral

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# RunwayML — video generation (5th mode)
# NOTE: Must also be set in ecosystem.config.cjs (read at module load time)
RUNWAY_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100,https://mumtaz.ai,https://www.mumtaz.ai,https://chat.mumtaz.ai,https://drama-queen.mumtaz.ai
