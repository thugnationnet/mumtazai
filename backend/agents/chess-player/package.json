{
  "name": "agent-chess-player",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Dedicated isolated backend for chess-player agent",
  "scripts": {
    "dev": "node server.js",
    "dev:watch": "nodemon --ext js --watch . server.js",
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "start": "node server.js",
    "lint": "eslint . --ext .js --fix",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.15.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@pinecone-database/pinecone": "^6.1.3",
    "file-type": "^19.6.0",
    "form-data": "^4.0.5",
    "sharp": "^0.34.5",
    "jsdom": "^26.1.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.12",
    "@anthropic-ai/sdk": "^0.71.2",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/generative-ai": "^0.24.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
